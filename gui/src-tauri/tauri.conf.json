{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "folco-gui",
  "version": "0.1.0",
  "identifier": "com.ecoates2.folco-gui",
  "build": {
    "beforeDevCommand": "bun run dev:app",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:app",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Folco",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "EJC: REPLACE THIS W/ <PUBLIC KEY CONTENT>",
      "endpoints": ["https://github.com/ecoates2/folco/releases/latest/download/latest.json"]
    }
  }
}
